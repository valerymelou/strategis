{
  "name": "strategis-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/strategis-web/src",
  "tags": [],
  "i18n": {
    "sourceLocale": {
      "code": "en",
      "subPath": ""
    },
    "locales": {
      "fr": {
        "translation": "apps/strategis-web/src/locale/fr/messages.fr.xlf",
        "subPath": ""
      }
    }
  },
  "targets": {
    "build": {
      "executor": "@nx/angular:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "plugins": ["apps/strategis-web/plugins/env-var-plugin.js"],
        "outputPath": "dist/apps/strategis-web",
        "browser": "apps/strategis-web/src/main.ts",
        "tsConfig": "apps/strategis-web/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/strategis-web/public"
          }
        ],
        "styles": ["apps/strategis-web/src/styles.css"]
      },
      "configurations": {
        "production": {
          "sourceMap": {
            "scripts": true
          },
          "localize": ["en"],
          "outputPath": "dist/apps/strategis-web/en",
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1.5mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "fr": {
          "sourceMap": {
            "scripts": true
          },
          "localize": ["fr"],
          "outputPath": "dist/apps/strategis-web/fr",
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1.5mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "index": "apps/strategis-web/src/locale/fr/index.html"
        },
        "development": {
          "localize": ["en"],
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/angular:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "strategis-web:build:production"
        },
        "development": {
          "buildTarget": "strategis-web:build:development"
        },
        "development-fr": {
          "buildTarget": "strategis-web:build:development,fr"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "ng-extract-i18n-merge:ng-extract-i18n-merge",
      "options": {
        "buildTarget": "strategis-web:build",
        "format": "xlf2",
        "outputPath": "apps/strategis-web/src/locale",
        "targetFiles": ["fr/messages.fr.xlf"],
        "sourceFile": "messages.xlf",
        "includeContext": true,
        "builderI18n": "@angular/build:extract-i18n"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/strategis-web/jest.config.cts",
        "tsConfig": "apps/strategis-web/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "strategis-web:build",
        "staticFilePath": "dist/apps/strategis-web/browser",
        "spa": true
      }
    },
    "copy-proxy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cp apps/strategis-web/src/proxy.mjs dist/apps/strategis-web/proxy.mjs"
      }
    },
    "package": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nx build strategis-web --configuration=production && nx build strategis-web --configuration=fr && nx run strategis-web:copy-proxy"
      }
    }
  }
}
