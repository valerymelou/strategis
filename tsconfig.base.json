{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@strategis/layout": ["./libs/layout/src/index.ts"],
      "@strategis/auth/data-access": ["./libs/auth/data-access/src/index.ts"],
      "@strategis/auth/login": ["./libs/auth/login/src/index.ts"],
      "@strategis/auth/register": ["./libs/auth/register/src/index.ts"],
      "@strategis/common/http": ["./libs/common/http/src/index.ts"],
      "@strategis/common/browser": ["./libs/common/browser/src/index.ts"],
      "@strategis/common/localize": ["./libs/common/localize/src/index.ts"],
      "@strategis/shared/theming": ["./libs/shared/theming/src/index.ts"],
      "@strategis/shared/ui": ["./libs/shared/ui/src/index.ts"],
      "@strategis/users/data-access": ["./libs/users/data-access/src/index.ts"],
      "@strategis/auth/layout": ["./libs/auth/layout/src/index.ts"],
      "@strategis/auth/email-verification": [
        "./libs/auth/email-verification/src/index.ts"
      ],
      "@strategis/profiles/data-access": [
        "./libs/profiles/data-access/src/index.ts"
      ],
      "@strategis/onboarding/shell": ["./libs/onboarding/shell/src/index.ts"],
      "@strategis/onboarding/profile": [
        "./libs/onboarding/profile/src/index.ts"
      ],
      "@strategis/onboarding/plan": ["./libs/onboarding/plan/src/index.ts"],
      "@strategis/onboarding/role": ["./libs/onboarding/role/src/index.ts"],
      "@strategis/admin/actors": ["./libs/admin/actors/src/index.ts"],
      "@strategis/admin/premium": ["./libs/admin/premium/src/index.ts"],
      "@strategis/profile": ["./libs/profile/src/index.ts"],
      "@strategis/roles": ["./libs/roles/src/index.ts"],
      "@strategis/subscription": ["./libs/subscription/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
